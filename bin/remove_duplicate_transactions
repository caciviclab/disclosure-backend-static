#!/bin/bash
set -euo pipefail

# 1. delete superseded report versions.
#
# NetFile's "efile_newest" yearly exports are supposed to contain only the
# newest version of each report, but they sometimes include both a report and
# the amendment that supersedes it, inside the same yearly file -- e.g. the
# 2024 export carried Report_Num 000 and 001 of Nikki Bas's Oct-Dec 2024
# report. (The yearly split itself is clean: each file holds exactly the
# reports whose period ends in that year, and no report appears in two
# files.) The Socrata portal mirrors the same duplicates. NetFile was
# notified in July 2026 and is working on an export-side fix; deduping here
# keeps the import correct regardless of source. Keep only the highest
# Report_Num for each (Filer_ID, From_Date, Thru_Date).
for table in Summary A-Contributions B1-Loans B2-Loans C-Contributions \
    D-Expenditure E-Expenditure F-Expenses F461P5-Expenditure \
    F465P3-Expenditure F496P3-Contributions G-Expenditure H-Loans \
    I-Contributions; do
  cat <<-QUERY | psql --quiet ${DATABASE_NAME:-"disclosure-backend"}
	\\set ON_ERROR_STOP on
	WITH latest AS (
	  SELECT "Filer_ID", "From_Date", "Thru_Date", max("Report_Num"::int) AS max_rpt
	  FROM "$table"
	  WHERE "From_Date" IS NOT NULL
	  GROUP BY 1, 2, 3
	)
	DELETE FROM "$table" t
	USING latest l
	WHERE t."Filer_ID" = l."Filer_ID"
	  AND t."From_Date" = l."From_Date"
	  AND t."Thru_Date" = l."Thru_Date"
	  AND t."Report_Num"::int < l.max_rpt;
	QUERY
done

# 2. delete transactions re-itemized across overlapping report periods.
#
# Committees sometimes file a later report whose period overlaps an earlier
# report (e.g. a semi-annual covering Jul-Dec after already filing Jul-Sep
# and Sep-Oct pre-election reports), re-listing the same transactions. Two
# rows are considered the same transaction only if they agree on Tran_ID,
# date, amount, AND contributor name (older NetFile Tran_IDs like "INC6"
# repeat across periods for different contributions, so Tran_ID alone is not
# sufficient). Keep the copy from the most recently filed report.
for table in A-Contributions C-Contributions I-Contributions \
    F496P3-Contributions; do
  cat <<-QUERY | psql --quiet ${DATABASE_NAME:-"disclosure-backend"}
	\\set ON_ERROR_STOP on
	WITH ranked AS (
	  SELECT ctid,
	    row_number() OVER (
	      PARTITION BY "Filer_ID", "Tran_ID", "Tran_Date", "Tran_Amt1",
	                   "Tran_NamL", "Tran_NamF"
	      ORDER BY "Rpt_Date" DESC, "Report_Num"::int DESC, "Thru_Date" DESC
	    ) AS rn,
	    first_value("From_Date") OVER (
	      PARTITION BY "Filer_ID", "Tran_ID", "Tran_Date", "Tran_Amt1",
	                   "Tran_NamL", "Tran_NamF"
	      ORDER BY "Rpt_Date" DESC, "Report_Num"::int DESC, "Thru_Date" DESC
	    ) AS kept_from,
	    first_value("Thru_Date") OVER (
	      PARTITION BY "Filer_ID", "Tran_ID", "Tran_Date", "Tran_Amt1",
	                   "Tran_NamL", "Tran_NamF"
	      ORDER BY "Rpt_Date" DESC, "Report_Num"::int DESC, "Thru_Date" DESC
	    ) AS kept_thru,
	    "From_Date", "Thru_Date"
	  FROM "$table"
	)
	DELETE FROM "$table" t
	USING ranked r
	WHERE t.ctid = r.ctid
	  AND r.rn > 1
	  AND (r."From_Date", r."Thru_Date")
	      IS DISTINCT FROM (r.kept_from, r.kept_thru);
	QUERY
done

# 3. delete duplicate 497 summary
cat <<-QUERY | psql ${DATABASE_NAME:-"disclosure-backend"}
DELETE FROM "496" late
WHERE EXISTS (
  SELECT * FROM "Summary" summary
      WHERE summary."Filer_ID"::varchar = late."Filer_ID"::varchar AND late."Exp_Date" <= summary."Thru_Date");
DELETE FROM "497" late
WHERE EXISTS (
  SELECT * FROM "Summary" summary
      WHERE summary."Filer_ID"::varchar = late."Filer_ID"::varchar AND late."Ctrib_Date" <= summary."Thru_Date");
QUERY
